rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidJob(data) {
      return data.keys().hasAll(['title', 'description', 'payment', 'location', 'contactInfo', 'createdAt', 'userId']) &&
             data.keys().size() <= 9 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             data.payment is string && data.payment.size() > 0 && data.payment.size() <= 50 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 100 &&
             data.contactInfo is string && data.contactInfo.size() > 0 && data.contactInfo.size() <= 100 &&
             data.createdAt is number &&
             (!('status' in data) || (data.status is string && data.status in ['open', 'accepted', 'completed'])) &&
             (!('acceptedBy' in data) || data.acceptedBy is string);
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(jobId) && isValidJob(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(jobId) && (
        (existing().userId == request.auth.uid && isValidJob(incoming()) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedBy']) && incoming().status == 'accepted' && incoming().acceptedBy == request.auth.uid && (!('status' in existing()) || existing().status == 'open'))
      );
      allow delete: if isSignedIn() && isValidId(jobId) && existing().userId == request.auth.uid;
    }
  }
}
